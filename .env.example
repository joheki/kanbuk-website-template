# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# Diese Variablen werden NUR vom Serverless-Kontaktendpoint (Vercel/Cloudflare) genutzt,
# niemals im statischen Build. Ohne sie funktioniert die Website – nur das Formular sendet nicht.

# API-Schlüssel von https://resend.com (kostenloses Kontingent reicht für Demos/Kleinbetriebe)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Absenderadresse. Muss eine bei Resend verifizierte Domain sein,
# z. B. "Website <noreply@dein-betrieb.at>". Für erste Tests: "onboarding@resend.dev"
CONTACT_FROM="Website <onboarding@resend.dev>"

# Optional: kostenloser Pexels-Key für Stockfoto-Platzhalter (nur lokal beim Bauen genutzt).
# Key holen: https://www.pexels.com/api/  →  dann:  npm run stock -- --thema "café interior"
PEXELS_API_KEY=
