{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_kommentar_de": "Der Port muss in EINEM Rutsch laufen. Deshalb ist alles vorab erlaubt, was dabei gebraucht wird - sonst muss bei jedem Schritt bestaetigt werden. Die deny-Liste bleibt eng: .env (Schluessel), zerstoererisches Loeschen, force-push.",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(node scripts/*)",
      "Bash(npx vercel*)",
      "Bash(npx degit*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(curl *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Read(./**)",
      "Edit(./**)",
      "Write(./**)",
      "WebFetch",
      "DesignSync"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Write(./.env)"
    ]
  }
}
