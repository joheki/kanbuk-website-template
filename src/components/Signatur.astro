---
/**
 * Signatur – MOTOR-Baustein: der Kanbuk-Backlink in der Fußzeile.
 *
 * Teil des Geschäftsmodells: Jede live geschaltete Kundenseite verlinkt
 * dezent auf kanbuk.com – ein dauerhafter Backlink von der Kundendomain.
 * Das Prüf-Tor erzwingt ihn bei der Live-Prüfung (npm run check -- --live);
 * ohne Signatur geht keine Seite live.
 *
 * Verwendung (in der Fußzeile des Kunden-Designs, neben © und Rechtslinks):
 *   <Signatur />                             → „Website von Kanbuk"
 *   <Signatur text="Webdesign: Kanbuk" />    → eigener Text (Marke bleibt)
 *
 * Absichtlich MARKEN-Anker („Kanbuk"), kein Keyword-Anker („Webdesign Wien"):
 * seitenweite Footer-Links mit Keyword-Text wertet Google als Link-Spam.
 * Der Markenname ist natürlich, unauffällig – und zählt trotzdem.
 *
 * ANKER-ROTATION: Ohne text-Prop wählt der Baustein DETERMINISTISCH eine
 * markenbasierte Variante – berechnet aus der Kundendomain. Dadurch ist der
 * Anker pro Kunde für immer stabil (ein je Build wechselnder Text wäre selbst
 * ein Spam-Signal), variiert aber über die Kundschaft hinweg. Alle Varianten
 * tragen die Marke – das Prüf-Tor lehnt jeden Anker ohne „Kanbuk" ab.
 */
import { site } from '../../content.config';

interface Props {
  text?: string;
  class?: string;
}

const VARIANTEN = [
  'Website von Kanbuk',
  'Webdesign: Kanbuk',
  'Erstellt von Kanbuk',
  'Eine Website von Kanbuk',
];
const schluessel = `${site.domain ?? ''}${site.betrieb.name ?? ''}`;
let summe = 0;
for (const zeichen of schluessel) summe = (summe + zeichen.charCodeAt(0)) % 9973;
const { text = VARIANTEN[summe % VARIANTEN.length], class: klasse } = Astro.props;
---

<a class:list={['signatur', klasse]} href="https://kanbuk.com" target="_blank" rel="noopener">
  {text}
</a>

<style>
  /* Bewusst dezent: erbt Schrift und Farbe der Fußzeile, leicht zurückgenommen.
     Das Design darf nachschärfen – aber nie verstecken (ein unsichtbarer Link
     ist auch für Google wertlos bis schädlich). */
  .signatur {
    color: inherit;
    opacity: 0.7;
    text-decoration: none;
    font-size: var(--schrift-s);
    white-space: nowrap;
  }
  .signatur:hover,
  .signatur:focus-visible {
    opacity: 1;
    text-decoration: underline;
  }
</style>
