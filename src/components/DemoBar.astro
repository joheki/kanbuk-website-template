---
/**
 * Schmale Leiste ganz oben – NUR im demo-Modus.
 * Kanbuk-Marken-Look: weiße „Cloud"-Leiste, schwarzes Zeichen + Wortmarke,
 * Vorschau-Text in Kanbuk-Violett, pulsierender grüner Punkt als Live-Anzeige.
 * Bewusst UNABHÄNGIG von den Kundenfarben – der Balken gehört zu Kanbuk,
 * nicht zum Kunden. (Weiß funktioniert auf hellen wie dunklen Kundendesigns,
 * weil die Leiste eine eigene, geschlossene Fläche ist.)
 */
import { Image } from 'astro:assets';
import { site } from '../../content.config';
// Das echte Kanbuk-Logo (Zeichen + Wortmarke, transparent) – Motor-Asset.
import logo from '../assets/kanbuk-logo.png';
---

<div class="demobar" role="note">
  {/* Über die Bild-Pipeline statt als rohes <img>: Die Leiste zeigt das Logo
      18 px hoch, die Datei ist 298 px breit – ungefiltert wären das ~8,6 KB
      für rund 8 % genutzte Pixel. width + densities liefern eine passende
      1x/2x-Variante als webp. */}
  <Image class="demobar__logo" src={logo} alt="Kanbuk" width={84} densities={[1, 2]} format="webp" />
  <span class="demobar__sep" aria-hidden="true"></span>
  <span class="demobar__puls" aria-hidden="true"></span>
  <span class="demobar__text">Vorschau für {site.betrieb.name}</span>
</div>

<style>
  .demobar {
    /* Fixe Kanbuk-Markenwerte – nicht aus den Kundenvariablen! */
    background: #ffffff;
    color: #18141f;
    border-bottom: 1px solid rgba(24, 20, 31, 0.08);
    box-shadow: 0 1px 10px rgba(24, 20, 31, 0.06);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
  }
  .demobar__logo {
    height: 18px;
    width: auto;
    display: block;
    flex: none;
  }
  .demobar__sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(24, 20, 31, 0.25);
    flex: none;
  }
  /* Live-Anzeige: pulsierender grüner Punkt (bei „Bewegung reduzieren" statisch). */
  .demobar__puls {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex: none;
    animation: demobar-puls 1.8s ease-out infinite;
  }
  @keyframes demobar-puls {
    0% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.45); }
    70% { box-shadow: 0 0 0 7px rgba(34, 197, 94, 0); }
    100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }
  .demobar__text {
    color: #6d28d9;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (max-width: 400px) {
    .demobar { font-size: 0.75rem; gap: 0.45rem; }
    .demobar__logo { height: 15px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .demobar__puls { animation: none; }
  }
</style>
