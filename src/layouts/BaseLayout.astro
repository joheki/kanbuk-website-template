---
/**
 * BaseLayout – das Grundgerüst jeder Seite. HIER sitzt der halbe Motor.
 *
 * Leistet je Seite:
 *  - eigener Titel, eigene Description, eigene Canonical, eigenes OG-Bild
 *  - Design-Tokens als CSS-Variablen (Nahtstelle zum Design)
 *  - JSON-LD LocalBusiness inkl. maschinenlesbarer Öffnungszeiten
 *  - hreflang, wenn mehrsprachig
 *  - demo-Modus: noindex (Meta; der HTTP-Header kommt über _headers/vercel.json)
 *  - startet die Verhaltens-Bausteine
 *
 * Das AUSSEHEN kommt aus dem Design – hier steht bewusst kein Layout.
 */
import '../styles/fonts.css';
import '../styles/global.css';
// Rohtext der Schriften-Deklarationen – fürs Vorladen unten ausgewertet.
import fontsCssRoh from '../styles/fonts.css?raw';
import { site, jsonLdTyp } from '../../content.config';
import { cssVariablen } from '../lib/theme';
import DemoBar from '../components/DemoBar.astro';
import Einwilligung from '../components/Einwilligung.astro';

interface Props {
  /** Pfad dieser Seite, z. B. '/speisekarte'. Muss in config.seiten stehen. */
  pfad?: string;
  /** Überschreibt den Titel aus der Seiten-Config (selten nötig). */
  titel?: string;
  /** Überschreibt die Description aus der Seiten-Config. */
  beschreibung?: string;
}

const { pfad = '/', titel, beschreibung } = Astro.props;

const seite = site.seiten.find((s) => s.pfad === pfad);
if (!seite && !titel) {
  throw new Error(
    `Seite "${pfad}" fehlt in content.config.ts -> seiten. Ohne Eintrag gibt es keine Meta-Angaben (Titel, Description) – das lässt "npm run check" nicht durch.`,
  );
}

const istDemo = site.mode === 'demo';

const seitenTitel = titel ?? seite!.metaTitel;
const vollerTitel =
  pfad === '/' ? `${site.betrieb.name} – ${site.betrieb.claim}` : `${seitenTitel} | ${site.betrieb.name}`;
const desc = beschreibung ?? seite?.metaBeschreibung ?? site.betrieb.kurzbeschreibung;
const canonical = new URL(pfad, site.domain).href;
const ogBild = new URL(seite?.ogBild ? `/${seite.ogBild}` : site.ogBild, site.domain).href;
const rootStyle = `:root { ${cssVariablen(site)} }`;

const mehrsprachig = site.sprachen.length > 1;

/** Kurzcodes -> volle schema.org-Tagesnamen. Google versteht NUR die vollen
    Namen ("Monday") – mit "Mo" würden die Öffnungszeiten still ignoriert. */
const TAG_LD: Record<string, string> = {
  Mo: 'Monday', Tu: 'Tuesday', We: 'Wednesday', Th: 'Thursday',
  Fr: 'Friday', Sa: 'Saturday', Su: 'Sunday',
};

/** Öffnungszeiten maschinenlesbar für JSON-LD (nur vollständige Angaben). */
const oeffnungszeitenLd = site.betrieb.oeffnungszeiten
  .filter((o) => o.tageISO?.length && o.vonISO && o.bisISO)
  .map((o) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: o.tageISO!.map((t) => TAG_LD[t] ?? t),
    opens: o.vonISO,
    closes: o.bisISO,
  }));

/**
 * Schriften vorladen – gegen das „Text hüpft kurz"-Problem (FOUT).
 *
 * fonts.css nutzt font-display: swap (richtig – Text darf nie unsichtbar
 * sein). Aber: Der Browser entdeckt Schriftdateien erst spät (CSS parsen →
 * Text ansehen → Datei anfordern). In dieser Lücke rendert die Ersatzschrift,
 * dann springt der Text auf die echte Schrift um. Mit rel="preload" starten
 * die Downloads sofort mit dem HTML – die Schrift ist praktisch immer vor dem
 * ersten Bild da.
 *
 * Vorgeladen werden NUR die Latin-Teilsätze (unicode-range U+0000-00FF …) –
 * die tragen den gesamten deutschen Text. Kyrillisch/Latin-Ext bleiben lazy;
 * sie vorzuladen wäre verschwendetes Datenvolumen und der Browser warnt über
 * ungenutzte Preloads. Fehlt einer Deklaration die unicode-range, wird sie
 * sicherheitshalber vorgeladen. Läuft zur BAUZEIT über fonts.css – funktioniert
 * damit für jede per `npm run schrift` eingebettete Schrift, kundenneutral.
 */
const schriftenVorladen = (() => {
  const urls = new Set<string>();
  for (const block of fontsCssRoh.match(/@font-face\s*{[^}]*}/g) ?? []) {
    const url = block.match(/url\('([^']+\.woff2)'\)/)?.[1];
    if (!url) continue;
    const range = block.match(/unicode-range:\s*([^;]+);/)?.[1];
    if (!range || /U\+0000-00FF/i.test(range)) urls.add(url);
  }
  return [...urls];
})();

/**
 * Speisekarte / Preisliste für Google (schema.org `hasMenu`).
 *
 * Die Daten liegen ohnehin strukturiert in der Config – daraus entsteht ohne
 * Zusatzaufwand ein Menu-Objekt. Google kann damit Gerichte, Preise und
 * Kategorien direkt in der Suche zeigen (Rich Result „Speisekarte"); ohne die
 * Angabe bleibt die Karte für Google eine Textwüste. Preise werden zu Zahlen
 * normalisiert („4,80 €" -> 4.80), weil schema.org nur Zahlen versteht.
 */
const menuLd = (() => {
  const liste = site.preisliste;
  if (!liste || liste.kategorien.length === 0) return {};
  const zahl = (p?: string) => {
    if (!p) return undefined;
    const t = p.replace(/[^0-9,.]/g, '').replace(',', '.');
    const n = Number.parseFloat(t);
    return Number.isFinite(n) ? n.toFixed(2) : undefined;
  };
  return {
    hasMenu: {
      '@type': 'Menu',
      name: 'Karte',
      ...(liste.pdfDatei && { url: `${site.domain.replace(/\/$/, '')}/${liste.pdfDatei}` }),
      hasMenuSection: liste.kategorien.map((kat) => ({
        '@type': 'MenuSection',
        name: kat.titel,
        ...(kat.untertitel && { description: kat.untertitel }),
        hasMenuItem: kat.gruppen.flatMap((gruppe) =>
          gruppe.positionen
            .filter((pos) => zahl(pos.preis ?? pos.varianten?.[0]?.preis))
            .map((pos) => ({
              '@type': 'MenuItem',
              name: pos.name,
              ...(pos.beschreibung && { description: pos.beschreibung }),
              offers: {
                '@type': 'Offer',
                price: zahl(pos.preis ?? pos.varianten?.[0]?.preis),
                priceCurrency: 'EUR',
              },
            })),
        ),
      })),
    },
  };
})();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': jsonLdTyp(site.branche),
  '@id': site.domain,
  name: site.betrieb.name,
  description: site.betrieb.kurzbeschreibung,
  url: site.domain,
  telephone: site.betrieb.telefon,
  email: site.betrieb.email,
  image: ogBild,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.betrieb.adresse.strasse,
    postalCode: site.betrieb.adresse.plz,
    addressLocality: site.betrieb.adresse.ort,
    addressCountry: site.betrieb.adresse.land ?? 'AT',
  },
  ...(oeffnungszeitenLd.length > 0 && { openingHoursSpecification: oeffnungszeitenLd }),
  ...(site.betrieb.socialLinks.length > 0 && {
    sameAs: site.betrieb.socialLinks.map((s) => s.url),
  }),
  ...menuLd,
};
---

<!doctype html>
<html lang="de-AT" data-animation={site.design.animation ?? 'dezent'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{vollerTitel}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />

    {/* Schriften sofort laden, nicht erst nach dem CSS-Parsen – sonst hüpft
        der Text von der Ersatzschrift auf die echte (Begründung oben).
        crossorigin ist bei Font-Preloads Pflicht, auch same-origin. */}
    {schriftenVorladen.map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}

    {/* demo = Vorschau: nie indexieren. Die 404 ist AUCH live nie indexierbar.
        Der HTTP-Header kommt im demo-Modus zusätzlich. */}
    <meta
      name="robots"
      content={istDemo || pfad === '/404' ? 'noindex, nofollow' : 'index, follow'}
    />

    {mehrsprachig && site.sprachen.map((s) => (
      <link
        rel="alternate"
        hreflang={s}
        href={new URL(s === 'de' ? pfad : `/${s}${pfad}`, site.domain).href}
      />
    ))}
    {mehrsprachig && <link rel="alternate" hreflang="x-default" href={canonical} />}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={vollerTitel} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="de_AT" />
    <meta property="og:image" content={ogBild} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {/* site_name erscheint in der Vorschau über dem Titel; die Bild-
        Beschreibung liest ein Screenreader beim geteilten Link vor.
        X/Twitter wertet og:image:alt NICHT aus – dort braucht es die
        eigene Angabe, sonst bleibt das Bild dort unbeschriftet. */}
    <meta property="og:site_name" content={site.betrieb.name} />
    <meta property="og:image:alt" content={`${site.betrieb.name} – ${site.betrieb.kurzbeschreibung}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={vollerTitel} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogBild} />
    <meta name="twitter:image:alt" content={`${site.betrieb.name} – ${site.betrieb.kurzbeschreibung}`} />

    <meta name="theme-color" content={site.design.farben.primaer} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {/* Design-Tokens: die Nahtstelle zwischen Claude Design und Motor. */}
    <style set:html={rootStyle}></style>
  </head>
  <body>
    {istDemo && <DemoBar />}
    <a class="skip-link" href="#inhalt">Zum Inhalt springen</a>
    <slot />

    {/* Rendert nur, wenn zustimmungspflichtige Dienste konfiguriert sind.
        Normalfall: nichts davon -> die Seite bleibt cookiefrei. */}
    <Einwilligung />

    <script>
      import { verhaltenStarten } from '../lib/verhalten';

      document.documentElement.classList.add('js');
      verhaltenStarten();

      // Dezentes Einblenden (progressive enhancement, ohne JS voll sichtbar).
      const ziele = document.querySelectorAll('[data-reveal]');
      const reduziert = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduziert || !('IntersectionObserver' in window)) {
        ziele.forEach((el) => el.classList.add('ist-sichtbar'));
      } else {
        const io = new IntersectionObserver(
          (eintraege) => {
            eintraege.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('ist-sichtbar');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
        );
        ziele.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
